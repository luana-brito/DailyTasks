PORT=3333
JWT_SECRET=gere-uma-string-longa-e-aleatoria
DATABASE_PATH=

# PostgreSQL (produção / Vercel): connection string completa.
# Ex.: Neon — copie "Connection string" no painel; use a URL com pooling para serverless.
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
#
# Local sem DATABASE_URL: SQLite em server/database.sqlite (LibSQL).

# Produção: origens do front (CORS), separadas por vírgula (opcional em dev).
# ALLOWED_ORIGINS=https://dailytasks.vercel.app

# Primeiro acesso: se não houver usuários, cria um admin
BOOTSTRAP_ADMIN_EMAIL=admin@local
BOOTSTRAP_ADMIN_PASSWORD=admin123

# Importação de backup JSON → SQLite (npm run import-firestore)
# IMPORT_DEFAULT_PASSWORD=senhaTemporariaParaUsuariosImportados
